{
  "name": "@repo/errors",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs-filter.d.ts",
      "import": "./dist/nestjs-filter.mjs",
      "require": "./dist/nestjs-filter.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/nestjs-filter.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/nestjs-filter.ts --format cjs,esm --dts --watch",
    "lint": "biome check --write",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
